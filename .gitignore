# ============================================
# Hollow Null Requiem - Unity Project .gitignore
# ============================================
# Project: Hollow Null Requiem (Unity 6, Android, 2D URP)
# Purchased assets managed separately via Google Drive

# ============================================
# Unity Generated Folders
# ============================================
/[Ll]ibrary/
/[Tt]emp/
/[Oo]bj/
/[Bb]uild/
/[Bb]uilds/
/[Ll]ogs/
/[Uu]serSettings/
/[Mm]emoryCaptures/
/[Rr]ecordings/
.utmp/

# ============================================
# Unity Gaming Services (UGS)
# ============================================
# UserSettings folder (already ignored above) contains:
# - CloudProjectData.json (developer-specific project linking)
# - EditorUserSettings.asset (local preferences)

# Authentication session cache (contains temporary tokens)
/[Aa]ssets/StreamingAssets/UnityServicesProjectConfiguration.json

# Service-specific generated caches
/[Aa]ssets/CloudCode/GeneratedCode/
/[Aa]ssets/EconomyResources/
/[Aa]ssets/RemoteConfig/

# UGS CLI configuration (if using CLI tools)
.ugs/
.ugsconfig

# ============================================
# Autogenerated IDE Files
# ============================================
# Unity regenerates these - no need to track
*.csproj
*.unityproj
*.sln
*.suo
*.tmp
*.user
*.userprefs
*.pidb
*.booproj
*.svd
*.pdb
*.mdb
*.opendb
*.VC.db

# ============================================
# IDE Cache and Config Folders
# ============================================
# Visual Studio
.vs/
.vscode/
.slnx

# JetBrains Rider
.idea/
*.sln.iml

# ============================================
# Build Output Files
# ============================================
*.apk
*.aab
*.unitypackage
*.app
*.ipa
*.exe
*.keystore

# Android specific
/[Aa]ssets/Plugins/Android/*.aar
/[Aa]ssets/Plugins/Android/libs/

# ============================================
# Unity3D Generated Meta Files for Ignored Items
# ============================================
*.pidb.meta
*.pdb.meta
*.mdb.meta

# ============================================
# macOS Specific Files
# ============================================
.DS_Store
._*
.Spotlight-V100
.Trashes
.AppleDouble
.LSOverride

# ============================================
# Windows Specific Files
# ============================================
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# ============================================
# Linux Specific Files
# ============================================
*~
.directory

# ============================================
# PURCHASED THIRD-PARTY ASSETS
# ============================================
# These assets are managed via Google Drive
# Must not be redistributed - excluded from repository
#
# Assets included in ThirdParty folder:
# 1. DOTween Pro (Demigiant)
# 2. Easy Save 3 (Moodkie)
# 3. Feel/MMFeedbacks (More Mountains)
# 4. Beautify 3 URP (Kronnect)
# 5. Character Editor Megapack (HIPPO)
# 6. Cartoon FX Remaster (Jean Moreno)
# 7. GUI Pro - Fantasy RPG (Layer Lab)
# 8. Synaptic AI Pro (MCP Integration)

# Exclude entire ThirdParty folder
/[Aa]ssets/ThirdParty/

# ============================================
# Easy Save 3 Generated Files
# ============================================
# Save files (keep .meta files for folder structure)
*.es3
/[Aa]ssets/Easy Save 3/

# Easy Save auto-generated types
/[Aa]ssets/Easy Save 3/Types/

# ============================================
# Asset Store Cache
# ============================================
AssetStoreTools/
/[Aa]ssets/AssetStoreTools/

# ============================================
# Additional Unity Logs
# ============================================
*.log
sysinfo.txt

# ============================================
# Audio Middleware (FMOD - if used in future)
# ============================================
.cache/
fmod.log
fmod_editor.log
/[Aa]ssets/Plugins/FMOD/Cache/

# ============================================
# Crashlytics
# ============================================
crashlytics-build.properties
fabric.properties

# ============================================
# TextMesh Pro (Keep if custom fonts added)
# ============================================
# Uncomment if you want to ignore TMP generated files
# /[Aa]ssets/TextMesh Pro/Resources/

# ============================================
# Custom Project Files to Ignore
# ============================================
# Development notes (keep in separate repo or local)
/DevNotes/
/Documentation/Private/
/Docs/
/.claude/
.mcp.json
*.md
!README.md
*.gitignore
*.gitattributes
*.jsx

# ============================================
# Tools and Scripts (Local Only)
# ============================================
# Card art generator and other automation tools
/Tools/

# Test builds
/TestBuilds/

# Profiler data
*.data

# Timeline cache
/[Aa]ssets/Timeline/Cache/

# Cinemachine cache (if used)
/[Aa]ssets/Cinemachine/

# Project analysis exports
/[Aa]ssets/ProjectAnalysis/

# Local testing folder
/[Aa]ssets/_Local/

# ============================================
# Temporary Files
# ============================================
*.swp
*.bak
*.tmp
*~.nib
*.orig

# ============================================
# Package Manager Locks (Keep for consistency)
# ============================================
# Uncomment if you want to ignore lock file
# /Packages/packages-lock.json

# ============================================
# END OF .gitignore
# ============================================
