  _eventId: Echo_WoundedTraveler
  _eventTitle: Wounded Traveler
  _narrative: A fellow wanderer lies wounded by the path. Their eyes plead for help,
    but the corruption spreading through their veins tells another story.
  _backgroundImage: {fileID: -7738117470717306996, guid: df3a460b51658194092c3541be3f3e57, type: 3}
  _choices:
  - _choiceText: Heal them (Lose 15 HP)
    _outcomeText: Your sacrifice purifies their wounds. They gift you an ancient
      remedy before departing.
    _outcomes:
    - _type: 4
      _value: 15
      _cardId: 
      _relicId: 
    - _type: 9
      _value: 10
      _cardId: 
      _relicId: 
  - _choiceText: End their suffering
    _outcomeText: A mercy killing. The corruption dissipates, leaving behind void
      shards.
    _outcomes:
    - _type: 1
      _value: 30
      _cardId: 
      _relicId: 
    - _type: 8
      _value: 5
      _cardId: 
      _relicId: 
  - _choiceText: Walk away
    _outcomeText: Their fate is not your burden. You continue on.
    _outcomes:
    - _type: 0
      _value: 0
