  _eventId: Echo_MemoryFragment
  _eventTitle: Memory Fragment
  _narrative: A crystallized memory floats before you - an echo of someone's final
    moments before the Hollow consumed them. Do you dare witness their fate?
  _backgroundImage: {fileID: 0}
  _choices:
  - _choiceText: Absorb the memory
    _outcomeText: Pain. Fear. Then... understanding. You learn from their mistakes.
    _outcomes:
    - _type: 8
      _value: 3
      _cardId: 
      _relicId: 
    - _type: 14
      _value: 0
      _cardId: 
      _relicId: 
  - _choiceText: Shatter the crystal
    _outcomeText: The memory disperses, leaving behind concentrated void essence.
    _outcomes:
    - _type: 1
      _value: 25
      _cardId: 
      _relicId: 
  - _choiceText: Leave it intact
    _outcomeText: Some memories deserve to persist. You feel strangely at peace.
    _outcomes:
    - _type: 9
      _value: 3
      _cardId: 
      _relicId: 
